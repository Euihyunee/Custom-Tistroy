s_list
  section#list(x-data='{ listStyle: "[##_list_style_##]" }')
    s_list_conform
      header(class='index-container pt-12 lg:pt-16')
        h1.tit(class='text-2xl lg:text-3xl font-bold text-h-800 dark:text-h-200') [##_list_conform_##]
    div(class='sticky top-14 z-20 bg-h-100/80 dark:bg-h-800/80 backdrop-blur py-4 border-b border-h-200 dark:border-h-700 index-container my-4')
      search.wrap(class='flex items-center gap-x-2 px-5 py-2 rounded-full border border-solid border-h-300 bg-white dark:border-h-600 dark:bg-h-700 shadow-sm max-w-lg mx-auto')
        s_search
          label(for='list-keyword' class='text-h-400')
            i.fa-solid.fa-magnifying-glass.text-sm
          input#list-keyword(
            type='text'
            name='[##_search_name_##]'
            value='[##_search_text_##]'
            placeholder='검색어를 입력하세요'
            onkeypress='if (event.keyCode == 13) { [##_search_onclick_submit_##] }'
            class='w-full bg-transparent border-0 outline-0 text-sm placeholder:text-h-400 text-h-600 dark:text-h-200 cursor-text')
    //- 카드 그리드 컨테이너: 카테고리/목록 페이지의 글들을 카드 형태로 배치
    ul.card-grid(class='index-container pt-8 lg:pt-10')
      s_list_rep
        li
          +index('list_rep')
    s_list_empty
      include List/Empty
